---
import ProjectCard from "./ProjectCard.astro";
---

<section class="container mx-auto mt-40 mb-10" id="project">
  <div class="flex justify-center md:justify-start">
    <h2 class="font-libre font-normal text-4xl md:text-5xl tracking-widest">
      Projects
    </h2>
  </div>
  <div class="mt-16 grid grid-cols-1 md:grid-cols-2 gap-5">
    <ProjectCard
      title="BookMyShow Ticket Notifier"
      description="Telegram bot that alerts users when tickets go live with real-time showtime monitoring."
      githubLink="https://github.com/tejaswankalluri/BookMyShow-Notifier"
      liveLink="https://t.me/notifymyshowbot"
    />
    <ProjectCard
      title="HeedTalk - A Debate App"
      description="Live audio debate platform with social profiles, following, and moderation tools."
      liveLink="https://heedtalk.com"
    />
    <ProjectCard
      title="LinkIt - share your social media links"
      description="Shareable profile page that bundles your social links with a clean public URL."
      githubLink="https://github.com/tejaswankalluri/LinkIt-Frontend"
      liveLink="https://linkit.tejaswan.me/"
    />
    <ProjectCard
      title="Url Shortner"
      description="Simple URL shortener with custom slugs and quick redirect performance."
      githubLink="https://github.com/tejaswankalluri/react-url-shortner"
      liveLink="https://react-url-shortner.netlify.app/"
    />
  </div>
</section>
