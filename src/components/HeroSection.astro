---
import { Image } from "astro:assets";
import HeroImg from "../assets/images/hero.jpg";
import Button from "./Button.astro";
---

<section class="container mx-auto min-h-screen flex items-center">
  <div
    class="flex flex-col gap-20 md:gap-0 md:flex-row md:justify-between items-center md:items-start"
  >
    <div class="flex flex-col gap-8 md:w-1/2">
      <div
        class="flex flex-col gap-3 font-medium text-center md:text-left md:mt-10"
      >
        <p class="text-3xl md:text-5xl">
          Hi<span class="wave" aria-hidden="true">👋</span>
        </p>
        <h1 class="text-3xl md:text-5xl md:mt-3">
          I'm <span class="font-normal underlineText font-libre tracking-widest"
            >Tejaswan</span
          >
        </h1>
      </div>
      <p class="text-sm text-center md:text-left md:text-base">
        I am a software engineer with over 3 years of experience in developing
        web and mobile applications. I have a passion for creating innovative
        solutions that solve real-world problems and enhance user experience.
      </p>
      <div class="mx-auto md:mx-0">
        <Button
          title="Resume"
          href="https://drive.google.com/file/d/1IhdAOP6xTkaWlcApjwj7baC_byQ2Ep0L/view?usp=sharing"
        />
      </div>
    </div>
    <div>
      <Image
        src={HeroImg}
        alt="Tejaswan Kalluri portrait"
        class="rounded-lg w-56 md:w-96 transition-transform duration-200 ease-out hover:scale-105"
        loading="eager"
        fetchpriority="high"
      />
    </div>
  </div>
</section>
<style>
  .wave {
    display: inline-block;
    transform-origin: 70% 70%;
  }

  .wave:hover {
    animation: wave 0.8s ease-in-out 1;
  }

  @keyframes wave {
    0% {
      transform: rotate(0deg);
    }
    20% {
      transform: rotate(18deg);
    }
    40% {
      transform: rotate(-10deg);
    }
    60% {
      transform: rotate(14deg);
    }
    80% {
      transform: rotate(-6deg);
    }
    100% {
      transform: rotate(0deg);
    }
  }

  .underlineText {
    display: inline-block;
    background-image: url("/underline.svg");
    background-repeat: no-repeat;
    background-size: contain;
    background-position: bottom;
    padding-bottom: 5px;
  }
</style>
